# ===== LLM (DeepSeek, OpenAI-compatible) =====
PG_MCP_OPENAI_API_KEY=sk-d59702c913f14c9c9de322474215db17
PG_MCP_OPENAI_BASE_URL=https://api.deepseek.com
PG_MCP_OPENAI_MODEL=deepseek-chat
PG_MCP_OPENAI_TIMEOUT_S=60

# ===== Databases (Docker Compose Postgres on localhost:5432) =====
PG_MCP_DATABASES=[{"name":"pgmcp_small","dsn":"postgresql://postgres:zycx@localhost:5432/pgmcp_small"},{"name":"pgmcp_medium","dsn":"postgresql://postgres:zycx@localhost:5432/pgmcp_medium"},{"name":"pgmcp_large","dsn":"postgresql://postgres:zycx@localhost:5432/pgmcp_large"}]
PG_MCP_DEFAULT_DATABASE=pgmcp_small

# ===== Safety / Limits =====
PG_MCP_STATEMENT_TIMEOUT_MS=30000
PG_MCP_MAX_ROWS=200
PG_MCP_ALLOW_MULTI_STATEMENT=false
PG_MCP_DISALLOWED_FUNCTIONS=["pg_sleep","pg_terminate_backend","pg_cancel_backend","pg_read_file","pg_write_file","pg_ls_dir"]

# ===== Optional meaning validation =====
PG_MCP_MEANING_VALIDATION_ENABLED=false
PG_MCP_MEANING_VALIDATION_MAX_RETRIES=1

# ===== Pooling =====
PG_MCP_POOL_MIN_SIZE=1
PG_MCP_POOL_MAX_SIZE=10
PG_MCP_POOL_IDLE_TIMEOUT_S=300

# ===== Schema refresh =====
PG_MCP_SCHEMA_REFRESH_INTERVAL_S=3600